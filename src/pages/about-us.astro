---
import BaseLayout from "src/layouts/BaseLayout.astro';
import Navbar from "src/components/Navbar.astro';
import Footer from "src/components/Footer.astro';

---

<BaseLayout title="About us" description="">

  <div class="page-wrapper">
    <Navbar />
    <div id="youtap-pos" class="section-about bg-biru">
      <div class="youtap---container w-container">
        <div data-w-id="17e3d935-1457-e95c-2a3a-6d06db475df1" class="youtap---inner-container left">
          <div class="headline-text">
            <div class="head-2" style="color: rgb(255, 255, 255);">
              <div class="sub-head white tentang-kami text-center" style="color: white;">Youtap Indonesia<br /></div>
              <h1 class="title center white text-center" style="color: white;"><strong>perusahaan teknologi yang berfokus pemberdayaan semua pelaku usaha</strong></h1>
              <div class="description white center" style="color: white;">Kami hadir memberikan solusi terbaik untuk semua pelaku usaha. Sebagai bagian dari Salim Group yang  resmi beroperasi pada Februari 2020, kami terus berinovasi dan menjadi bagian dalam memajukan perekonomian Indonesia.<br /></div>
            </div>
          </div>
        </div>
        <div class="container-video">
          <div style="padding-top:56.17021276595745%" class="w-embed-youtubevideo youtube"><iframe src="https://www.youtube.com/embed/g5dP3RHvEhM?rel=0&amp;controls=1&amp;autoplay=0&amp;mute=0&amp;start=0" frameborder="0" style="position:absolute;left:0;top:0;width:100%;height:100%;pointer-events:auto" allow="autoplay; encrypted-media" allowfullscreen="" title="Bersama Youtap #SemuaBisa Jadi BOS"></iframe></div>
        </div>
      </div>
    </div>
    <div id="youtap-bos" class="section-about white about">
      <div class="youtap---container w-container">
        <div data-w-id="17e3d935-1457-e95c-2a3a-6d06db475e4b" class="container-image remove-shadow"><img sizes="(max-width: 1919px) 100vw, 1920px" srcset="/images/MAPS-YOUTAP-MERCHANT-p-500.png 500w, /images/MAPS-YOUTAP-MERCHANT-p-800.png 800w, /images/MAPS-YOUTAP-MERCHANT-p-1080.png 1080w, /images/MAPS-YOUTAP-MERCHANT-p-1600.png 1600w, /images/MAPS-YOUTAP-MERCHANT.png 1920w" alt="maps youtap merchant indonesia besar" src="/images/MAPS-YOUTAP-MERCHANT.png" class="youtap-image" /></div>
        <div data-w-id="3852e2a5-2962-65f2-aeb7-d7f135f67edc" class="w-layout-grid grid-new-youtap _2-grid">
          <div class="sub-head normal bold"><strong>TENTANG  YOUTAP INDONESIA​</strong><br /></div>
          <div class="description">Youtap Indonesia menyediakan platform dan solusi digital untuk semua bisnis dan perusahaan. Menghadirkan berbagai transaksi digital terkini kepada mitra kami agar dapat lebih baik melayani konsumen.<br /><br />​​Kami ingin menjadi yang terbesar di Indonesia untuk jaringan penerimaan transaksi dan juga menjangkau potensi diluar transaksi pembayaran. Kami menawarkan solusi layanan digital terlengkap untuk membantu semua pelaku usaha dalam menjalankan kegiatan usahanya sehari hari.​<br /></div>
        </div>
      </div>
    </div>
    <div id="youtap-bos" class="section-about white visi">
      <div class="youtap---container w-container">
        <div data-w-id="2dd3f155-59e8-3f15-4b32-f286a592ec37" class="youtap---inner-container left">
          <div class="headline-text left">
            <div class="head-2">
              <div class="sub-head normal center">Visi Kami:<br /></div>
              <h1 class="title center"><strong class="bold">&quot;Hadir bagi semua pelaku usaha, mendukung, dan memberdayakan mereka untuk mencapai hasil terbaik&quot;</strong></h1>
            </div>
          </div>
        </div>
        <div data-w-id="8b4b16c1-9d04-84a3-83d8-1b89e09de3da" class="container-image remove-shadow"><img sizes="(max-width: 1260px) 100vw, 1260px" srcset="/images/LOGO-ICON-p-500.webp 500w, /images/LOGO-ICON-p-800.webp 800w, /images/LOGO-ICON-p-1080.webp 1080w, /images/LOGO-ICON.webp 1260w" alt="Logo icon youtap" src="/images/LOGO-ICON.webp" class="youtap-image" /></div>
      </div>
    </div>
    <div id="youtap-pay" class="section-about photo">
      <div class="youtap---container center w-container">
        <div class="w-layout-grid content-usp-youtap">
          <div id="w-node-_665907ca-d815-f90d-fcb0-d5d5ec869e2e-53856ac7" class="usp">
            <h2 class="counterup-copy">510+</h2>
            <div class="text-block-30-copy">KOTA</div>
          </div>
          <div id="w-node-_238fe982-368d-8a1b-ac04-1f2159aa2ef1-53856ac7" class="usp">
            <h2 class="counterup-copy">500 K+</h2>
            <div class="text-block-30-copy">MERCHANT</div>
          </div>
          <div class="usp">
            <h2 class="counterup-copy">70+</h2>
            <div class="text-block-30-copy">PAYMENT PROVIDER</div>
          </div>
        </div>
      </div>
      <a href="https://bos.youtap.id/supplier/detail?ss=youtap-official-store-sf6pr&amp;utm_source=WEBSITE&amp;utm_medium=Product_Banner_YOS&amp;utm_campaign=Traffic_YOS" target="_blank" class="w-inline-block"><img src="/images/Merchant-Cafe.png" loading="lazy" sizes="(max-width: 1760px) 100vw, 1760px" srcset="/images/Merchant-Cafe-p-500.png 500w, /images/Merchant-Cafe-p-800.png 800w, /images/Merchant-Cafe-p-1080.png 1080w, /images/Merchant-Cafe-p-1600.png 1600w, /images/Merchant-Cafe.png 1760w" alt="banner merchant cafe" class="youtap-image" /></a>
    </div>
  </div>
  <Footer />
  <div class="whatsapp-block whatsapp-block-2">
    <div class="whatsapp-chat">
      <div class="top-section"><img src="/images/WA-Logo-Blue.png" loading="lazy" width="47" sizes="(max-width: 479px) 100vw, 47px" alt="" srcset="/images/WA-Logo-Blue-p-500.png 500w, /images/WA-Logo-Blue-p-800.png 800w, /images/WA-Logo-Blue-p-1080.png 1080w, /images/WA-Logo-Blue.png 1376w" class="live-icon-chat" />
        <div class="top-text-container">
          <div class="live-chat-top-text">Alisa Youtap</div>
          <div class="live-chat-bottom-text">Typically replies in a few hours</div>
        </div>
        <div id="close-chat" data-w-id="adb9e51c-9985-4c7e-860a-77ed9ebdae1b" class="close-live-chat-container"><img src="/images/close-live-chat.svg" loading="lazy" alt="" class="close-livechat-icon" /></div>
      </div>
      <div class="chat-section">
        <div class="chat-block">
          <div class="live-chat-top-text block">Alisa Youtap</div>
          <div class="live-chat-bottom-text block">Halo! Ada yang bisa Alisa bantu?</div>
        </div>
      </div>
      <a href="https://api.whatsapp.com/send?phone=6281113109357&amp;text=Halo+admin+Youtap+Indonesia" target="_blank" class="live-chat-link w-inline-block">
        <div class="livechat-button"><img src="/images/small-whatsapp.svg" loading="lazy" alt="" class="small-whatsapp-icon" />
          <div class="live-chat-text">Start Whatsapp Chat</div>
        </div>
      </a>
    </div>
    <div id="whatsapp-button" data-w-id="adb9e51c-9985-4c7e-860a-77ed9ebdae28" class="whatsapp-container"><img src="/images/whatsapp.svg" loading="lazy" alt="" class="whatsapp-icon" />
      <div class="live-icon"></div>
    </div>
  </div>
  <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=616d24eebbeca651471d975d" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script is:inline src="/js/youtap-indonesia.js" type="text/javascript"></script>
  <script is:inline src="https://cdn.prod.website-files.com/gsap/3.15.0/gsap.min.js" type="text/javascript"></script>
  <script is:inline src="https://cdn.prod.website-files.com/gsap/3.15.0/SplitText.min.js" type="text/javascript"></script>
  <script is:inline src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" type="text/javascript"></script><!--  Google Tag Manager (noscript)  -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W2DNLPB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!--  End Google Tag Manager (noscript)  -->

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);

      // Animasi Fade-in & Up untuk elemen teks
      gsap.utils.toArray('.title, .description, .sub-head').forEach((el) => {
        gsap.from(el, {
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
          },
          y: 40,
          opacity: 0,
          duration: 0.8,
          ease: "power2.out"
        });
      });

      // Animasi stagger untuk elemen USP (Angka statistik)
      const usps = document.querySelectorAll('.usp');
      if (usps.length > 0) {
        gsap.from(usps, {
          scrollTrigger: {
            trigger: usps[0],
            start: "top 85%",
          },
          y: 50,
          opacity: 0,
          duration: 0.8,
          stagger: 0.2,
          ease: "power2.out"
        });
      }
    }
  });
</script>

</BaseLayout>
