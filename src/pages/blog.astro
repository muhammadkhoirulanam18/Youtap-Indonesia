---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/home/CTA.astro';

const mainBlogs = [
  {
    title: "Cara Meningkatkan Penjualan dengan Youtap POS",
    category: "Berita Terbaru",
    date: "10 Juli 2026",
    readTime: "5 Min Read",
    description: "Pelajari bagaimana Youtap POS dapat membantu Anda mengelola inventaris, mempercepat transaksi, dan memantau laporan penjualan secara real-time.",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  },
  {
    title: "5 Tips Sukses Membangun Bisnis F&B dari Nol",
    category: "Tips & Trik",
    date: "08 Juli 2026",
    readTime: "4 Min Read",
    description: "Menjalankan bisnis F&B membutuhkan strategi yang tepat. Berikut adalah 5 tips untuk memastikan bisnis makanan dan minuman Anda sukses di pasaran.",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  },
  {
    title: "Pentingnya Pembayaran Digital di Era Modern",
    category: "Inspirasi",
    date: "05 Juli 2026",
    readTime: "3 Min Read",
    description: "Dengan semakin banyaknya konsumen yang beralih ke cashless, mengetahui pentingnya sistem pembayaran digital sangat penting untuk pertumbuhan UMKM.",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  }
];

const tabBlogs = [
  {
    title: "Promo Kemerdekaan: Diskon Langganan POS 50%",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  },
  {
    title: "Update Fitur Terbaru Youtap BOS Bulan Ini",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  },
  {
    title: "Kisah Sukses Kopi Kenangan Menggunakan Youtap",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  },
  {
    title: "Panduan Lengkap Pendaftaran QRIS untuk Merchant",
    image: "https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg"
  }
];
---

<BaseLayout title="Blog" description="">

  <Navbar />
  <section class="section-highlight-2">
    <div class="w-dyn-list">
      <div role="list" class="collection-list-18 w-dyn-items">
        {mainBlogs.map(blog => (
          <div role="listitem" class="div-block-1294 w-dyn-item">
            <a href="#" class="list-blog-3 w-inline-block">
              <div class="div-block-1298 list-blog-3"><img loading="lazy" src={blog.image} alt={blog.title} class="thumbnail-img-blog-2" />
                <div class="div-block-1297">
                  <div class="blog-category">
                    <div class="categories">
                      <div class="text-block-78">{blog.category}</div>
                    </div>
                  </div>
                  <h3 fs-cmsfilter-field="IDENTIFIER" class="title-list-blog-3">{blog.title}</h3>
                  <div class="w-layout-hflex flex-block-19">
                    <div class="w-layout-hflex blok-info-list-blog">
                      <div class="info-visitor-blog-2">{blog.date} • {blog.readTime}</div>
                    </div>
                  </div>
                  <p class="thumbnail-description-blog">{blog.description}</p>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
      <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination-2">
        <a href="#" aria-label="Previous Page" class="w-pagination-previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
            <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
          </svg>
          <div class="w-inline-block">Previous</div>
        </a>
        <a href="#" aria-label="Next Page" class="w-pagination-next">
          <div class="w-inline-block">Next</div><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
            <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
  <div data-duration-in="300" data-duration-out="100" data-current="Terbaru" data-easing="ease" class="tabs w-tabs">
    <div class="tabs-menu w-tab-menu">
      <a data-w-tab="Terbaru" class="blog-tab-menu w-inline-block w-tab-link w--current">
        <div class="text-block-24">Postingan Terbaru</div>
      </a>
      <a data-w-tab="Promo" class="blog-tab-menu w-inline-block w-tab-link">
        <div>Promo</div>
      </a>
      <a data-w-tab="Inspirasi" class="blog-tab-menu w-inline-block w-tab-link">
        <div>Inspirasi</div>
      </a>
      <a data-w-tab="Tips" class="blog-tab-menu w-inline-block w-tab-link">
        <div>Tips</div>
      </a>
      <a data-w-tab="Berita" class="blog-tab-menu w-inline-block w-tab-link">
        <div>Berita</div>
      </a>
      <a data-w-tab="Event" class="blog-tab-menu w-inline-block w-tab-link">
        <div>Event</div>
      </a>
    </div>
    <div class="tabs-content w-tab-content">
      <div data-w-tab="Terbaru" class="tab-pane-tab-1 w-tab-pane w--tab-active">
        <div class="cl-newest-post-1 w-dyn-list">
          <div role="list" class="collection-list-6 w-dyn-items">
            {tabBlogs.map(blog => (
              <div role="listitem" class="w-dyn-item">
                <a href="#" class="blog-list-v w-inline-block">
                  <div class="blog-list-v-image" style={`background-image: url('${blog.image}'); background-size: cover; background-position: center;`}></div>
                  <div class="div-title-v">
                    <div class="title-list-1">{blog.title}</div>
                    <div class="div-block-43">Baca Selengkapnya</div>
                  </div>
                </a>
              </div>
            ))}
          </div>
          <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination">
            <a href="#" aria-label="Previous Page" class="w-pagination-previous previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
              </svg></a>
            <a href="#" aria-label="Next Page" class="w-pagination-next next"><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
              </svg></a>
          </div>
        </div>
      </div>
      <div data-w-tab="Promo" class="w-tab-pane">
        <div class="cl-newest-post-1 w-dyn-list">
          <div role="list" class="collection-list-6 w-dyn-items">
            <div role="listitem" class="w-dyn-item">
              <a href="#" class="blog-list-v w-inline-block">
                <div class="blog-list-v-image"></div>
                <div class="div-title-v">
                  <div class="title-list-1 w-dyn-bind-empty"></div>
                  <div class="div-block-43"></div>
                </div>
              </a>
            </div>
          </div>
          <div class="w-dyn-empty">
            <div>No items found.</div>
          </div>
          <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination">
            <a href="#" aria-label="Previous Page" class="w-pagination-previous previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
              </svg></a>
            <div aria-label="Page 1 of 1" role="heading" class="w-page-count page-count"></div>
            <a href="#" aria-label="Next Page" class="w-pagination-next next"><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
              </svg></a>
          </div>
        </div>
      </div>
      <div data-w-tab="Inspirasi" class="w-tab-pane">
        <div class="cl-newest-post-1 w-dyn-list">
          <div role="list" class="collection-list-6 w-dyn-items">
            <div role="listitem" class="w-dyn-item">
              <a href="#" class="blog-list-v w-inline-block">
                <div class="blog-list-v-image"></div>
                <div class="div-title-v">
                  <div class="title-list-1 w-dyn-bind-empty"></div>
                  <div class="div-block-43"></div>
                </div>
              </a>
            </div>
          </div>
          <div class="w-dyn-empty">
            <div>No items found.</div>
          </div>
          <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination">
            <a href="#" aria-label="Previous Page" class="w-pagination-previous previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
              </svg></a>
            <a href="#" aria-label="Next Page" class="w-pagination-next next"><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
              </svg></a>
          </div>
        </div>
      </div>
      <div data-w-tab="Tips" class="w-tab-pane">
        <div class="cl-newest-post-1 w-dyn-list">
          <div role="list" class="collection-list-6 w-dyn-items">
            <div role="listitem" class="w-dyn-item">
              <a href="#" class="blog-list-v w-inline-block">
                <div class="blog-list-v-image"></div>
                <div class="div-title-v">
                  <div class="title-list-1 w-dyn-bind-empty"></div>
                  <div class="div-block-43"></div>
                </div>
              </a>
            </div>
          </div>
          <div class="w-dyn-empty">
            <div>No items found.</div>
          </div>
          <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination">
            <a href="#" aria-label="Previous Page" class="w-pagination-previous previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
              </svg></a>
            <a href="#" aria-label="Next Page" class="w-pagination-next next"><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
              </svg></a>
          </div>
        </div>
      </div>
      <div data-w-tab="Berita" class="w-tab-pane">
        <div class="cl-newest-post-1 w-dyn-list">
          <div role="list" class="collection-list-6 w-dyn-items">
            <div role="listitem" class="w-dyn-item">
              <a href="#" class="blog-list-v w-inline-block">
                <div class="blog-list-v-image"></div>
                <div class="div-title-v">
                  <div class="title-list-1 w-dyn-bind-empty"></div>
                  <div class="div-block-43"></div>
                </div>
              </a>
            </div>
          </div>
          <div class="w-dyn-empty">
            <div>No items found.</div>
          </div>
          <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination">
            <a href="#" aria-label="Previous Page" class="w-pagination-previous previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
              </svg></a>
            <a href="#" aria-label="Next Page" class="w-pagination-next next"><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
              </svg></a>
          </div>
        </div>
      </div>
      <div data-w-tab="Event" class="w-tab-pane">
        <div class="cl-newest-post-1 w-dyn-list">
          <div role="list" class="collection-list-6 w-dyn-items">
            {tabBlogs.map(blog => (
              <div role="listitem" class="w-dyn-item">
                <a href="#" class="blog-list-v w-inline-block">
                  <div class="blog-list-v-image" style={`background-image: url('${blog.image}'); background-size: cover; background-position: center;`}></div>
                  <div class="div-title-v">
                    <div class="title-list-1">{blog.title}</div>
                    <div class="div-block-43">Baca Selengkapnya</div>
                  </div>
                </a>
              </div>
            ))}
          </div>
          <div role="navigation" aria-label="List" class="w-pagination-wrapper pagination">
            <a href="#" aria-label="Previous Page" class="w-pagination-previous previous"><svg class="w-pagination-previous-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M8 10L4 6l4-4"></path>
              </svg></a>
            <a href="#" aria-label="Next Page" class="w-pagination-next next"><svg class="w-pagination-next-icon" height="12px" width="12px" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 12 12" transform="translate(0, 1)">
                <path fill="none" stroke="currentColor" fill-rule="evenodd" d="M4 2l4 4-4 4"></path>
              </svg></a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <CTA />
  <Footer />
  <script is:inline src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=616d24eebbeca651471d975d" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
  <script is:inline src="/js/youtap-indonesia.js" type="text/javascript"></script>
  <script is:inline src="https://cdn.prod.website-files.com/gsap/3.15.0/gsap.min.js" type="text/javascript"></script>
  <script is:inline src="https://cdn.prod.website-files.com/gsap/3.15.0/SplitText.min.js" type="text/javascript"></script>
  <script is:inline src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" type="text/javascript"></script><!--  Google Tag Manager (noscript)  -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W2DNLPB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!--  End Google Tag Manager (noscript)  -->

</BaseLayout>
