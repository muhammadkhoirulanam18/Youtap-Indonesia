      <div class="top-section"><img src="/images/WA-Logo-Blue.png" loading="lazy" width="47" sizes="(max-width: 479px) 100vw, 47px" alt="" srcset="/images/WA-Logo-Blue-p-500.png 500w, /images/WA-Logo-Blue-p-800.png 800w, /images/WA-Logo-Blue-p-1080.png 1080w, /images/WA-Logo-Blue.png 1376w" class="live-icon-chat" />
