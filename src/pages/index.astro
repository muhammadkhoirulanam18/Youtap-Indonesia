---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import YoutapPOS from "../components/home/YoutapPOS.astro";
import YoutapBOS from "../components/home/YoutapBOS.astro";
import YoutapPAY from "../components/home/YoutapPAY.astro";
import YoutapKiosk from "../components/home/YoutapKiosk.astro";
import YoutapLoyalty from "../components/home/YoutapLoyalty.astro";
import Solutions from "../components/home/Solutions.astro";
