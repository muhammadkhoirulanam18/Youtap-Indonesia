        </a>
        <div class="w-locales-list">
          <div data-delay="0" data-hover="true" class="dropdown w-dropdown">
            <div class="spark-nav-link-5 lang-dropdwon w-dropdown-toggle">
              <div class="icon-dropwodn w-icon-dropdown-toggle"></div>
              <div class="text-block-74">Bahasa</div>
            </div>
            <nav class="w-dropdown-list">
              <div role="list" class="w-locales-items">
                <div role="listitem" class="w-locales-item">
                  <a hreflang="id" href="#" class="wg-dropdown-1-link w-inline-block"><img loading="lazy" src="/images/Flag_of_Indonesia.png" alt="icon bahasa indonesia" class="lang-img" />
